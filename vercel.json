{
  "buildCommand": "node ./node_modules/vite/bin/vite.js build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://regenerative-tax.webflow.io"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://regenerative-tax.webflow.io https://*.webflow.io"
        }
      ]
    }
  ]
}